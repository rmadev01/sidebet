APP_ENV=development

# Shared database
# Use localhost for local dev. Docker Compose overrides service-internal DATABASE_URLs to use the
# `postgres` service hostname automatically.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sidebet

# Backend server
HOST=0.0.0.0
PORT=3000
DB_MAX_CONNECTIONS=50
DB_ACQUIRE_TIMEOUT_SECS=5
REQUEST_TIMEOUT_SECS=15
MAX_REQUEST_BODY_BYTES=65536
EVENTS_SYNC_COOLDOWN_SECS=60
FRONTEND_URL=http://localhost:5173

# Auth sidecar
AUTH_SECRET=replace-with-a-long-random-secret
BETTER_AUTH_URL=http://localhost:3001
AUTH_PORT=3001
AUTH_DB_MAX_CONNECTIONS=20
AUTH_RATE_LIMIT_WINDOW_SECS=60
AUTH_RATE_LIMIT_MAX=20
AUTH_COOKIE_DOMAIN=
BACKEND_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# External APIs
SPORTSGAMEODDS_API_KEY=replace-with-your-sportsgameodds-key

# Frontend (public)
# These values are baked into the frontend build during `docker compose build` and should also be
# configured in the Vercel project if you deploy `frontend/` there.
PUBLIC_API_URL=http://localhost:3000
PUBLIC_AUTH_URL=http://localhost:3001
PUBLIC_WS_URL=ws://localhost:3000/api/ws
